# LLM API Configuration - OpenAI (Recommended for MiroFish)
# Get your key from: https://platform.openai.com/api-keys
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
# gpt-4o-mini is cost-effective (~$3 per full BTC sim)
# gpt-4o for higher quality predictions
LLM_MODEL_NAME=gpt-4o-mini

# ===== ZEP Memory Graph Configuration =====
# Get free quota from: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== OPTIONAL: Acceleration LLM (faster graph building) =====
# Uncomment if you want a cheaper model for initial heavy lifting
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== BTC SIMULATION TUNING (override via env) =====
# Number of simulation rounds (higher = more converged prediction, more cost)
# 10 = quick test, 50 = standard, 120 = deep analysis
OASIS_DEFAULT_MAX_ROUNDS=50
